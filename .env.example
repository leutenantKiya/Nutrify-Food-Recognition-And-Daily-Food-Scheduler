# NutriFile API — Environment Configuration
# Copy this to .env and fill in your values

# ── Chat API (Google Gemini) ──────────────────────────────────────────
# Get your key from: https://aistudio.google.com/apikey
NUTRIFILE_CHAT_API_KEY=your_gemini_api_key_here

# ── Optional overrides ───────────────────────────────────────────────
# NUTRIFILE_HOST=0.0.0.0
# NUTRIFILE_PORT=8001
# NUTRIFILE_DEBUG=true
# NUTRIFILE_WEIGHTS_DIR=path/to/weights
# NUTRIFILE_UPLOAD_DIR=path/to/uploads
